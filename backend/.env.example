RASENTINEL_APP_NAME=RASentinel
RASENTINEL_ENV=development
RASENTINEL_API_PREFIX=/api/v1

# Storage policy:
# Leave these empty to use the OS app-data location.
# Windows default: C:\Users\<user>\AppData\Roaming\rasentinel-desktop\data\rasentinel.db
# macOS default: ~/Library/Application Support/rasentinel-desktop/data/rasentinel.db
# Linux default: ~/.local/share/rasentinel-desktop/data/rasentinel.db
RASENTINEL_DATA_DIR=
RASENTINEL_DATABASE_URL=

RASENTINEL_LOG_LEVEL=INFO
RASENTINEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
